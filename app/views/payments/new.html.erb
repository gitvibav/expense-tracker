<div class="main">
  <h1 class="page-title">Settle Up</h1>
  
  <% if @users_i_owe.empty? %>
    <div class="card">
      <div class="flash flash-notice">
        You don't owe anyone anything! 🎉
      </div>
      <div class="text-center">
        <%= link_to "Back to Dashboard", dashboard_path, class: "btn btn-secondary" %>
      </div>
    </div>
  <% else %>
    <div class="card">
      <%= form_with(model: @payment, local: true, class: "payment-form") do |form| %>
        <% if @payment.errors.any? %>
          <div class="flash flash-alert">
            <h3 style="margin: 0 0 0.5rem; font-size: 1rem;"><%= pluralize(@payment.errors.count, "error") %> prohibited this payment from being saved:</h3>
            <ul style="margin: 0; padding-left: 1.25rem;">
              <% @payment.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-group">
          <%= form.label :to_user_id, "Who are you paying?", class: "form-label" %>
          <%= form.select :to_user_id, 
              @users_i_owe, 
              { prompt: "Select a person" }, 
              { class: "form-input" } %>
        </div>

        <div class="form-group">
          <%= form.label :amount, "Amount (Rs)", class: "form-label" %>
          <%= form.number_field :amount, 
              min: 0.01, 
              step: 0.01, 
              class: "form-input", 
              placeholder: "e.g., 28.17" %>
        </div>

        <div class="form-group">
          <%= form.label :notes, "Notes (optional)", class: "form-label" %>
          <%= form.text_area :notes, 
              rows: 3, 
              class: "form-input", 
              placeholder: "Add any notes about this payment..." %>
        </div>

        <div class="expense-form-actions">
          <%= form.submit "Record Payment", class: "btn btn-primary" %>
          <%= link_to "Cancel", dashboard_path, class: "btn btn-secondary" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
