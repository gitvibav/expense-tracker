<% content_for :title, "Sign in – Expense Tracker" %>

<div class="card">
  <h1 class="page-title">Sign in</h1>

  <%= form_with url: session_path, method: :post do |f| %>
    <div class="form-group">
      <%= label_tag :email, "Email", class: "form-label" %>
      <%= email_field_tag :email, params[:email], class: "form-input", required: true, autocomplete: "email" %>
    </div>
    <div class="form-group">
      <%= label_tag :password, "Password", class: "form-label" %>
      <%= password_field_tag :password, nil, class: "form-input", required: true, autocomplete: "current-password" %>
    </div>

    <div class="expense-form-actions">
      <%= submit_tag "Sign in", class: "btn btn-primary" %>
      <%= link_to "Create an account", sign_up_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

